# Public Arc Testnet values. NEXT_PUBLIC_* values are visible in the browser.
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARCSCAN_URL=https://testnet.arcscan.app
NEXT_PUBLIC_USDC=0x3600000000000000000000000000000000000000

# Public deployed Arc Testnet contract addresses
NEXT_PUBLIC_WALLET_FACTORY=0x1Da7E51b537F9E6CF5bB308b3B2d6fdc5D9E4750
NEXT_PUBLIC_POLICY_ENGINE=0x767C95C3E914d63bD26a5f1cDE4d6DA950462112
NEXT_PUBLIC_ESCALATION_MANAGER=0x6E03e0030fCeE242E2cCB77Da8D7C6c93a36A37E
NEXT_PUBLIC_ANOMALY_ORACLE=0x7A80C967A69E1d1a6bb2286089BB5945f3274cf4
NEXT_PUBLIC_VENDOR_REGISTRY=0x4A4d419292F2E374421B45907861BBB5adA6eF82

# Supabase read-model integration. The service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server/API runtime. Do not put these values in NEXT_PUBLIC variables.
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
SIWE_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_SECRET
ARCANUM_OPEN_REGISTRATION=true
ARCANUM_DEPLOYMENT_MODE=supabase

# Optional legacy local tooling only. Vercel web/API runtime does not use DATABASE_URL.
DATABASE_URL=

# Optional demo workspace gating
ARCANUM_DEMO_OWNER_WALLET=
ARCANUM_DEMO_ORG_SLUG=
ARCANUM_DEMO_ORG_NAME=

# Server-only local deployment credentials. Not required for normal web runtime.
# Never commit real values.
DEPLOYER_PRIVATE_KEY=
ANOMALY_ORACLE_PRIVATE_KEY=
